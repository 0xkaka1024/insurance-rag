# 复制本文件为 .env 并填入真实 key（.env 已被 gitignore，不会上传）
DEEPSEEK_API_KEY=sk-xxxxxxxx
SILICONFLOW_API_KEY=sk-xxxxxxxx

# SiliconFlow 有两个独立平台，key 互不通用、模型目录不同：
#   国内站 siliconflow.cn         -> base https://api.siliconflow.cn/v1（默认；有 BAAI/bge-m3、bge-reranker-v2-m3）
#   国际站 cloud.siliconflow.com  -> base https://api.siliconflow.com/v1（无 bge 系，用 Qwen3 系）
# 国际站账号请取消注释以下三行：
# SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# P1 阶段才需要（Qwen-VL / qwen-plus 对比）
DASHSCOPE_API_KEY=
